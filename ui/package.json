{
  "name": "olympus-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "setup": "bunx msw init public/ --save",
    "test:e2e": "bun run test:e2e:desktop && bun run test:e2e:mobile",
    "test:e2e:desktop": "bash scripts/maestro-test.sh mock",
    "test:e2e:mobile": "bash scripts/maestro-test.sh mobile",
    "test:e2e:live": "bash scripts/maestro-test.sh live",
    "test:e2e:prod": "bash scripts/maestro-test.sh prod"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/kit": "^7.21.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-virtual": "^3.10.0",
    "@uiw/react-codemirror": "^4.25.10",
    "date-fns": "^3.6.0",
    "msw": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.0",
    "react-syntax-highlighter": "^15.5.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tanstack/router-devtools": "^1.167.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.21",
    "vitest": "^4.1.9"
  }
}
