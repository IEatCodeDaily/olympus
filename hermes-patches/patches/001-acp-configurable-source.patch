+def _session_source() -> str:
+    """Source tag for sessions this ACP adapter owns.
+
+    Defaults to ``"acp"`` (editor integrations: VS Code, Zed, JetBrains). A host
+    that drives ``hermes acp`` as its own first-class channel can override this
+    via ``HERMES_ACP_SESSION_SOURCE`` so its sessions are tagged distinctly in
+    ``state.db`` (e.g. Olympus sets ``HERMES_ACP_SESSION_SOURCE=olympus``) and
+    show up as their own channel in ``session_search`` / Studio / Olympus.
+
+    The value is sanitised to a conservative ``[a-z0-9_]`` slug; an empty or
+    invalid override falls back to ``"acp"`` so a bad env var can never produce
+    an unfilterable/blank source.
+    """
+    raw = (os.environ.get("HERMES_ACP_SESSION_SOURCE") or "").strip().lower()
+    slug = re.sub(r"[^a-z0-9_]", "", raw)
+    return slug or "acp"
+
