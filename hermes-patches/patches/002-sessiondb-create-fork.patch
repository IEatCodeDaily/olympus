+
+    def create_fork(
+        self,
+        src_id: str,
+        fork_point_msg_id: int = None,
+        *,
+        source: str = "acp",
+        fork_type: str = "cross-channel",
+        new_cwd: str = None,
+        model: str = None,
+        new_session_id: str = None,
+    ) -> Optional[str]:
+        """Create an ACP-resumable fork of an existing session.
+
+        Copies active messages from ``src_id`` up to ``fork_point_msg_id`` into a
+        fresh branch session without mutating the source. The fork is marked as a
+        branch child via both ``parent_session_id`` and
+        ``model_config._branched_from`` so Hermes session lists keep it visible
+        rather than treating it as an ephemeral delegate child.
+
+        Returns the new session id, or ``None`` if the source session does not
+        exist or the selected fork range contains no active messages.
+        """
+        if not src_id:
+            return None
+
+        fork_id = new_session_id or str(uuid.uuid4())
+        target_source = (source or "acp").strip() or "acp"
+        fork_kind = (fork_type or "cross-channel").strip() or "cross-channel"
+
+        def _do(conn):
+            src = conn.execute(
+                "SELECT * FROM sessions WHERE id = ?",
+                (src_id,),
+            ).fetchone()
+            if src is None:
+                return None
+
+            point_clause = ""
+            params: List[Any] = [src_id]
+            if fork_point_msg_id is not None:
+                point_clause = " AND id <= ?"
+                params.append(fork_point_msg_id)
+
+            active_count = conn.execute(
+                "SELECT COUNT(*) AS c FROM messages "
+                "WHERE session_id = ? AND active = 1" + point_clause,
+                params,
+            ).fetchone()["c"]
+            if int(active_count or 0) <= 0:
+                return None
+
+            src_meta: Dict[str, Any] = {}
+            raw_meta = src["model_config"]
+            if raw_meta:
+                try:
+                    parsed = json.loads(raw_meta)
+                    if isinstance(parsed, dict):
+                        src_meta = parsed
+                except (json.JSONDecodeError, TypeError):
+                    src_meta = {}
+
+            fork_cwd = new_cwd or src_meta.get("cwd") or src["cwd"] or "."
+            fork_meta = dict(src_meta)
+            fork_meta["cwd"] = fork_cwd
+            fork_meta["_branched_from"] = src_id
+            fork_meta["_fork_type"] = fork_kind
+            if fork_point_msg_id is not None:
+                fork_meta["_fork_point_msg_id"] = fork_point_msg_id
+
+            conn.execute(
+                """
+                INSERT INTO sessions (
+                    id, source, user_id, model, model_config, system_prompt,
+                    parent_session_id, cwd, started_at,
+                    message_count, tool_call_count,
+                    input_tokens, output_tokens,
+                    cache_read_tokens, cache_write_tokens, reasoning_tokens,
+                    title, archived
+                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 0, 0, 0, 0, 0, 0, 0, NULL, 0)
+                """,
+                (
+                    fork_id,
+                    target_source,
+                    src["user_id"],
+                    model or src["model"],
+                    json.dumps(fork_meta),
+                    src["system_prompt"],
+                    src_id,
+                    fork_cwd,
+                    time.time(),
+                ),
+            )
+
+            copy_params: List[Any] = [fork_id, src_id]
+            copy_point_clause = ""
+            if fork_point_msg_id is not None:
+                copy_point_clause = " AND id <= ?"
+                copy_params.append(fork_point_msg_id)
+            conn.execute(
+                """
+                INSERT INTO messages (
+                    session_id, role, content, tool_call_id, tool_calls, tool_name,
+                    timestamp, token_count, finish_reason,
+                    reasoning, reasoning_content, reasoning_details,
+                    codex_reasoning_items, codex_message_items,
+                    platform_message_id, observed, active, compacted
+                )
+                SELECT
+                    ?, role, content, tool_call_id, tool_calls, tool_name,
+                    timestamp, token_count, finish_reason,
+                    reasoning, reasoning_content, reasoning_details,
+                    codex_reasoning_items, codex_message_items,
+                    platform_message_id, COALESCE(observed, 0), 1, 0
+                FROM messages
+                WHERE session_id = ? AND active = 1
+                """
+                + copy_point_clause
+                + " ORDER BY id",
+                copy_params,
+            )
+
+            conn.execute(
+                """
+                UPDATE sessions
+                SET
+                    message_count = (
+                        SELECT COUNT(*) FROM messages
+                        WHERE session_id = ? AND active = 1
+                    ),
+                    tool_call_count = (
+                        SELECT COALESCE(SUM(
+                            CASE
+                                WHEN tool_calls IS NOT NULL AND json_valid(tool_calls)
+                                THEN json_array_length(tool_calls)
+                                ELSE 0
+                            END
+                        ), 0)
+                        FROM messages
+                        WHERE session_id = ? AND active = 1
+                    )
+                WHERE id = ?
+                """,
+                (fork_id, fork_id, fork_id),
+            )
+            return fork_id
+
+        return self._execute_write(_do)
+
