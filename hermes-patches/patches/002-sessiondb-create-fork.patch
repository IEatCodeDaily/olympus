+def test_acp_fork_session_can_branch_observed_source_session(tmp_path, monkeypatch):
+    """Cross-channel continuation forks observed DB rows into this ACP source."""
+    from hermes_state import SessionDB
+
+    db = SessionDB(db_path=tmp_path / "state.db")
+    db.create_session(
+        session_id="telegram-src",
+        source="telegram",
+        model="fake-model",
+        model_config={"cwd": "/chat"},
+        cwd="/chat",
+    )
+    db.append_message("telegram-src", role="user", content="hello from telegram")
+
+    monkeypatch.setenv("HERMES_ACP_SESSION_SOURCE", "olympus")
+    fake = FakeAgent()
+    manager = SessionManager(agent_factory=lambda **kwargs: fake, db=db)
+
+    forked = manager.fork_session("telegram-src", cwd="/olympus")
+
+    assert forked is not None
+    assert forked.session_id != "telegram-src"
+    assert forked.cwd == "/olympus"
+    assert [(m.get("role"), m.get("content")) for m in forked.history] == [
+        ("user", "hello from telegram")
+    ]
+
+    fork_row = db.get_session(forked.session_id)
+    assert fork_row["source"] == "olympus"
+    assert fork_row["parent_session_id"] == "telegram-src"
+    assert db.get_session("telegram-src")["source"] == "telegram"
+
+
